{
  "Console log": {
    "prefix": "log",
    "body": ["console.log(\"${1:message}\", ${2:value});"],
    "description": "Console.log with message and value"
  },
  "Dynamic import": {
    "prefix": "dimport",
    "body": ["import ${1:name} from '${2:path}'$0"],
    "description": "Dynamic import statement"
  },
  "Arrow Function": {
    "prefix": "afn",
    "body": ["const ${1:functionName} = (${2:param}) =>"],
    "description": "Create an arrow function"
  },
  "Comment block": {
    "prefix": "comm",
    "body": ["/**", " * ${1:COMMENT}", " */"],
    "description": "Add COMMENT: item"
  },
  "TODO": {
    "prefix": "todo",
    "body": ["/** TODO: $1*/"],
    "description": "Add TODO: item"
  },
  "NOTE": {
    "prefix": "note",
    "body": ["/** NOTE: $1*/"],
    "description": "Add NOTE: item"
  },
  "Prettier ignore": {
    "prefix": "prettierignore",
    "body": ["/* eslint-disable prettier/prettier */", "${1:// code to ignore}", "/* eslint-enable */"],
    "description": "Creates a block to disable prettier formatting"
  },
  "HTML Button": {
    "prefix": "btn",
    "body": ["<button type=\"${1:type}\">${2:content}</button>"],
    "description": "Create an HTML button element"
  },
  "Class Attribute": {
    "prefix": "cls",
    "body": ["class=\"${1:className}\""],
    "description": "Insert class attribute with placeholder"
  }
}
