# adjust-cell-width = "-2%"
# adjust-cell-height = "-5%"

window-decoration = none
# background-opacity = 0.95

font-size = 20

font-family = MesloLGS Nerd Font Mono
# font-family = RobotoMono Nerd Font Mono
# font-family = Inconsolata Nerd Font Mono
# font-family = Consolas

# font-family = JetBrainsMono Nerd Font Mono
  
# font-thicken = true
# adjust-underline-position = 8

adjust-underline-thickness = 2
alpha-blending = linear-corrected
font-feature = -calt

  
title = " "
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
macos-option-as-alt = true


# Theme - managed by `theme` shell command (light/dark)
theme = Dark+

# Cursor color - override theme cursor to magenta (must be after theme)
cursor-color = #bf68d9

# Keybindings
keybind = ctrl+t>t=text:tt\r

