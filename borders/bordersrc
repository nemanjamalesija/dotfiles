#!/bin/bash

# Theme-aware accent: monokai yellow (dark) / magenta (light)
if [ -f "$HOME/.theme-mode" ] && [ "$(cat "$HOME/.theme-mode" | tr -d '[:space:]')" = "dark" ]; then
    accent=0xffffd866 # monokai yellow
else
    accent=0xffbf68d9 # magenta
fi

options=(
    style=round
    width=10.0
    hidpi=off
    active_color=$accent
    inactive_color=0xff333333
)
borders "${options[@]}"
